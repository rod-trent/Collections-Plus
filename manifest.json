{
  "manifest_version": 3,
  "name": "Collections Plus",
  "version": "2.1.0",
  "description": "Save pages, images & notes into collections — with dead-link snapshots, sharing, AI search & organize, a reading list, and more.",
  "minimum_chrome_version": "114",
  "homepage_url": "https://github.com/rod-trent/Collections-Plus",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "sidePanel",
    "contextMenus",
    "tabs",
    "tabGroups",
    "scripting",
    "alarms",
    "bookmarks"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "omnibox": {
    "keyword": "col"
  },
  "commands": {
    "save-current-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Save the current page to Collections Plus"
    }
  },
  "action": {
    "default_title": "Collections Plus",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
